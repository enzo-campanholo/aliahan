{
  "name": "aliahan",
  "version": "1.0.0",
  "description": "A local course planning app",
  "scripts": {
    "build:css": "tailwindcss -i priv/input.css -o priv/app.css",
    "check:js": "node --check priv/app.js",
    "vendor:alpine": "cp node_modules/alpinejs/dist/cdn.min.js priv/alpine.min.js",
    "watch:css": "tailwindcss -i priv/input.css -o priv/app.css --watch"
  },
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "alpinejs": "^3.15.8",
    "tailwindcss": "^4.2.2"
  }
}
